# ===================================================================
# PRODUCTION ENVIRONMENT VARIABLES FOR VERCEL
# ===================================================================
# Instructions:
# 1. Go to Vercel Dashboard → Your Project → Settings → Environment Variables
# 2. Add each variable below for "Production" environment
# 3. Replace placeholder values with your actual credentials
# ===================================================================

# ================================
# Supabase Authentication (REQUIRED)
# ================================
# Get from: https://app.supabase.com → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ================================
# Application URLs (REQUIRED)
# ================================
# Replace with your actual Vercel production domain
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
NODE_ENV=production

# ================================
# AWS S3 Storage (REQUIRED for file uploads)
# ================================
# SECURITY: Add these in Vercel Dashboard, not in code
# Create IAM user with S3-only permissions for security
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_S3_BUCKET=derma-ai-storage
NEXT_PUBLIC_AWS_S3_BUCKET=derma-ai-storage
NEXT_PUBLIC_S3_REGION=ap-south-1
NEXT_PUBLIC_AWS_REGION=ap-south-1

# ================================
# Optional Services (Disable until ready)
# ================================
# Set API_URL to "disabled" until FastAPI backend is deployed
API_URL=disabled
ENABLE_ML_PREDICTIONS=false
ENABLE_PAYMENTS=false
ENABLE_EMAIL_NOTIFICATIONS=false

# ================================
# Optional API Keys (Add when ready)
# ================================
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIza...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...

# ================================
# Rate Limiting & CORS
# ================================
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000
ALLOWED_ORIGINS=https://your-domain.vercel.app

# ================================
# Development Flags (Keep false in production)
# ================================
DEBUG_MODE=false
MOCK_AWS_SERVICES=false
